# Database (NeonDB)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/willbry?sslmode=require

# JWT
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# Groq AI
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=willbry-assets
R2_PUBLIC_URL=https://assets.willbry.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@willbry.com

# App URLs
APP_URL=https://api.willbry.com
FRONTEND_URL=https://willbry.com
PORT=8080
